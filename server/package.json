{
  "name": "malir-marketplace-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Backend API + database foundation for the Malir Cantt Marketplace (Phase 5.1)",
  "main": "src/server.js",
  "scripts": {
    "postinstall": "node scripts/postinstall.js",
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "generate": "prisma generate",
    "migrate": "prisma migrate dev",
    "seed": "node prisma/seed.js",
    "create-admin": "node scripts/create-admin.js",
    "setup": "prisma migrate dev --name init && prisma generate && node prisma/seed.js",
    "studio": "prisma studio"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^6.2.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^9.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "prisma": "^6.2.1"
  }
}
