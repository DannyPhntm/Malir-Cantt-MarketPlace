# Database — Neon Postgres (schema.prisma uses provider = "postgresql").
#   DATABASE_URL = POOLED connection (host contains "-pooler") — app runtime.
#   DIRECT_URL   = DIRECT connection (no "-pooler") — used by prisma migrate.
# Both come from the Neon dashboard; keep ?sslmode=require.
# (For local SQLite instead: set provider="sqlite" and DATABASE_URL="file:./dev.db".)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/DBNAME?sslmode=require"

# Server
PORT=4000

# CORS — browser origin(s) allowed to call the API (comma-separated for several).
# Dev: the Vite server. Production: set to your deployed frontend domain.
CLIENT_ORIGIN=http://localhost:5173

# Auth — REQUIRED. Use a long random string. In production the server refuses to
# start if this is unset (no insecure default). Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Verification / reset / email-change code lifetime (minutes)
CODE_TTL_MINUTES=10

# Email (Resend) — leave RESEND_API_KEY blank for local dev (codes are logged
# server-side only, never returned to the client). Set RESEND_API_KEY + MAIL_FROM
# to send real email via Resend (https://resend.com).
#   - RESEND_API_KEY: from the Resend dashboard (starts with `re_`).
#   - MAIL_FROM: a verified sender. Use `onboarding@resend.dev` to test before
#     verifying your own domain.
RESEND_API_KEY=
MAIL_FROM=onboarding@resend.dev
# Where contact-form submissions are emailed (the human support inbox).
# Sent FROM MAIL_FROM. Defaults to support@malircanttbazaar.com if unset.
CONTACT_TO_EMAIL=support@malircanttbazaar.com

# Admin seed (optional) — used by `npm run create-admin`. If ADMIN_PASSWORD is
# unset, a strong random password is generated and printed once.
ADMIN_EMAIL=admin@malircantt.pk
ADMIN_PASSWORD=
