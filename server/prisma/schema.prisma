// Malir Cantt Marketplace — database schema (Phase 5.1)
//
// SQLite for local dev; the column/table names are snake_case (production
// convention) while the JS layer uses camelCase via @map / @@map.
//
// To move to Postgres: change `provider` to "postgresql", point DATABASE_URL at
// the Postgres URL, and the String status/type fields below can be promoted to
// native enums (SQLite does not support enums, so they are validated in the app
// layer — see src/validators/schemas.js for the allowed values).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Users ────────────────────────────────────────────────────────────────────
model User {
  id               Int      @id @default(autoincrement())
  name             String
  email            String   @unique
  passwordHash     String   @map("password_hash")
  phone            String
  canttPassNumber  String?  @map("cantt_pass_number")
  residentLocation String   @map("resident_location")
  avatarUrl        String?  @map("avatar_url") // base64 data-URL or external URL; null = use initials
  accountType      String   @default("personal") @map("account_type") // personal | business
  role             String   @default("user") // user | admin
  businessVerified Boolean  @default(false) @map("business_verified")
  emailVerified    Boolean  @default(false) @map("email_verified")
  createdAt        DateTime @default(now()) @map("created_at")

  listings        Listing[]
  businessAccount BusinessAccount?
  savedListings   SavedListing[]
  shop            Shop?

  @@map("users")
}

// ── Listings ─────────────────────────────────────────────────────────────────
model Listing {
  id                Int      @id @default(autoincrement())
  userId            Int      @map("user_id")
  title             String
  description       String
  category          String // vehicles | property | electronics | home-living | fashion | services | food | jobs | fitness | other
  subcategory       String?  @map("subcategory") // slug within the category, or null
  postingType       String   @default("personal") @map("posting_type") // personal | business
  shopId            Int?      @map("shop_id") // business listings link to the poster's Shop (directory) when they have one
  price             Int // stored in PKR (whole rupees)
  featuredRequested Boolean  @default(false) @map("featured_requested")
  featuredActive    Boolean  @default(false) @map("featured_active")
  // Monetization-ready (no payments yet): a future timestamp = promotion active.
  // Set manually / by admin for now; a payment gateway can populate them later.
  featuredUntil     DateTime? @map("featured_until")
  boostedUntil      DateTime? @map("boosted_until")
  status            String   @default("pending") // pending | approved | rejected | sold | hidden
  // Category-specific attributes (make/model/year, bedrooms, foodType, …) stored
  // as a JSON string — the set of fields varies by category (see categoryConfig).
  details           String?
  createdAt         DateTime @default(now()) @map("created_at")

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  shop    Shop?          @relation(fields: [shopId], references: [id], onDelete: SetNull)
  images  ListingImage[]
  savedBy SavedListing[]

  @@index([userId])
  @@index([category])
  @@index([status])
  @@index([shopId])
  @@map("listings")
}

// ── Saved listings (favourites) ──────────────────────────────────────────────
model SavedListing {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  listingId Int      @map("listing_id")
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@index([userId])
  @@map("saved_listings")
}

// ── Listing images ───────────────────────────────────────────────────────────
// Count rule (min 1 for all categories except jobs/services, max 10) is enforced
// at the API validation layer — see listingCreateSchema in src/validators.
model ListingImage {
  id           Int    @id @default(autoincrement())
  listingId    Int    @map("listing_id")
  imageUrl     String @map("image_url")
  displayOrder Int    @default(0) @map("display_order")

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@map("listing_images")
}

// ── Business accounts ────────────────────────────────────────────────────────
// One-to-one with User. `paymentStatus` mirrors the frontend premiumConfig:
// not_required (billing disabled) | unpaid | paid.
model BusinessAccount {
  id            Int     @id @default(autoincrement())
  userId        Int     @unique @map("user_id")
  businessName  String  @map("business_name")
  businessType  String? @map("business_type")
  sellerStatus  String  @default("not_applied") @map("seller_status")
  paymentStatus String  @default("payment_required") @map("payment_status")

  // ── Business authenticity (beta) ─────────────────────────────────────────
  // Collected at apply time so admins can verify the business is real before
  // approval. The document URLs are PRIVATE — admin-only; never returned by the
  // public seller/shop endpoints (those use explicit field selects).
  businessAddress         String? @map("business_address")
  businessPhone           String? @map("business_phone")
  // Required proof of business (bill / receipt / business card / lease …).
  verificationDocUrl      String? @map("verification_doc_url")
  verificationDocPublicId String? @map("verification_doc_public_id")
  verificationDocLabel    String? @map("verification_doc_label")
  // Optional during beta — owner CNIC photo + NTN / registration number.
  cnicDocUrl              String? @map("cnic_doc_url")
  cnicDocPublicId         String? @map("cnic_doc_public_id")
  ntnNumber               String? @map("ntn_number")
  // Admin's note on the decision — doubles as the rejection reason shown to the
  // applicant. Visible to the owner + admins only; never on public endpoints.
  adminNotes              String? @map("admin_notes")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("business_accounts")
}

// ── Shops (business directory) ───────────────────────────────────────────────
// A permanent shop/business profile (distinct from item listings). One shop per
// approved business user. Public sees only `approved` shops.
model Shop {
  id                Int      @id @default(autoincrement())
  userId            Int      @unique @map("user_id")
  name              String
  shopCategory      String   @map("shop_category")
  sells             String? // free-text "what they sell" tags
  description       String?
  location          String
  phone             String
  whatsapp          String?
  openingHours      String?  @map("opening_hours")
  deliveryAvailable Boolean  @default(false) @map("delivery_available")
  logoUrl           String?  @map("logo_url")
  images            String? // JSON array of image URLs / data-URLs
  status            String   @default("pending") // pending | approved | hidden
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  listings Listing[]

  @@index([shopCategory])
  @@index([status])
  @@map("shops")
}

// ── Email verification codes ─────────────────────────────────────────────────
model EmailVerificationCode {
  id        Int      @id @default(autoincrement())
  email     String
  code      String
  expiresAt DateTime @map("expires_at")
  verified  Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([email])
  @@map("email_verification_codes")
}

// ── Password reset codes ─────────────────────────────────────────────────────
model PasswordResetCode {
  id        Int      @id @default(autoincrement())
  email     String
  code      String
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([email])
  @@map("password_reset_codes")
}

// ── Contact form submissions ─────────────────────────────────────────────────
// Stored from the public Contact page. `category` is the inquiry type
// (general | business | featured | bug | scam | suggestion). No email
// integration yet — submissions are persisted (and logged in dev).
model ContactMessage {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  subject   String
  message   String
  category  String   @default("general")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("contact_messages")
}
